% ===========================================================
% STOCK QUERY RULES
% ===========================================================

% Stock info lookup
stock_info_data(Symbol, Info) :-
    stock_company(Symbol, Company),
    stock_price(Symbol, Price),
    stock_sector(Symbol, Sector),
    stock_market_cap(Symbol, MarketCap),
    stock_pe_ratio(Symbol, PE),
    stock_rating(Symbol, Rating),
    stock_sentiment(Symbol, Sentiment).

% Position gain/loss
position_gain_loss(User, Symbol, GainLoss) :-
    user_portfolio(User, Symbol, Shares, PurchasePrice),
    stock_price(Symbol, CurrentPrice),
    Diff is CurrentPrice - PurchasePrice,
    GainLoss is Diff * Shares.
