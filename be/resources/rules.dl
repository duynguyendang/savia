% ===========================================================
% SAVIA SECURITY GATES
% ===========================================================

% --- 0. DYNAMIC INPUT SCHEMAS (Placeholders) ---
intent("sys_init").
has_role("sys_init", "none").
user_tenure_years("sys_init", 0).
chat_history("sys_init").
bq_result("sys_init").
is_empty("").

halt(ErrorMsg) :-
    intent(I),
    required_role(I, Role),
    !has_role(_, Role),
    ErrorMsg = "SECURITY VIOLATION".

required_role("check_balance", "customer").
required_role("transaction_history", "customer").
required_role("admin_settings", "admin").

% ===========================================================
% SAVIA KNOWLEDGE REGISTRY & ROUTING
% ===========================================================

% --- 1. SEARCH STRATEGY ROUTING ---
search_strategy("structured_sql") :- intent("check_balance").
search_strategy("structured_sql") :- intent("transaction_history").
search_strategy("structured_sql") :- intent("stock_price").
search_strategy("structured_sql") :- intent("stock_info").

search_strategy("vector_semantic") :- intent("policy_inquiry").
search_strategy("vector_semantic") :- intent("unknown").

% --- 2. SQL TEMPLATE REGISTRY ---
query_sql("get_balance", "SELECT balance, currency FROM `savia.finance.accounts` WHERE user_id = @user_id").
query_sql("vector_search", "SELECT text_content FROM VECTOR_SEARCH(TABLE `savia.knowledge.policies`, 'embedding_col', (SELECT ml_generate_embedding_result FROM ML.GENERATE_EMBEDDING(MODEL `savia.models.embed`, (SELECT @query_text AS content))), top_k => 2)").

% --- 3. PROMPT BLUEPRINT REGISTRY ---
prompt_blueprint("standard_data", "
    System: You are Savia. Vibe: {{vibe}}.
    Context: The user asked about {{intent}}.
    Truth Data: {{data}}.
    History: {{history}}.
    Instruction: Answer concisely using the Truth Data.
").

prompt_blueprint("missing_data", "
    System: You are Savia. Vibe: Empathetic.
    Instruction: Politely inform the user that data for {{intent}} is not available. Suggest checking 'Balance'.
").

prompt_blueprint("stock_info", "
    System: You are Savia. You are a knowledgeable financial advisor.
    Context: {{data}}.
    History: {{history}}.
    Instruction: Provide a helpful, concise summary of the stock information. Include the price, company name, sector, and any notable metrics.
").

% --- 4. SYNTHESIS LOGIC ---
active_template("standard_data") :- bq_result(D), !is_empty(D).
active_template("missing_data")  :- bq_result(D), is_empty(D).
active_template("stock_info")   :- intent(I), I = "stock_info".

prompt_var("vibe", "Warm and Professional") :- user_tenure_years(_, Y), Y > 3.
prompt_var("vibe", "Efficient and Direct")  :- user_tenure_years(_, Y), Y <= 3.
prompt_var("data", D) :- bq_result(D).
prompt_var("history", H) :- chat_history(H).

% --- 5. VOICE STEERING ---
voice_data("analytical", "21m00Tcm4TlvDq8ikWAM").
voice_data("empathetic", "AZnzlk1XvdvUeBnXmlld").

voice_style("empathetic") :- user_tenure_years(_, Y), Y > 3.
voice_style("analytical") :- user_tenure_years(_, Y), Y <= 3.
voice_style("analytical") :- search_strategy("structured_sql").
voice_style("empathetic") :- search_strategy("vector_semantic").

active_voice_id(ID) :-
    voice_style(Style),
    voice_data(Style, ID).

